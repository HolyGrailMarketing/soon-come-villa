# Soon Come Villa — serverless environment variables.
# Copy to your Vercel project (vercel env add) — do NOT commit real values.

# Neon Postgres connection string (pooled, with sslmode=require).
DATABASE_URL=postgres://user:pass@ep-xxxx.neon.tech/neondb?sslmode=require

# DimePay credentials.
DIMEPAY_CLIENT_ID=ck_...            # public client key (reaches the browser)
DIMEPAY_SECRET_KEY=sk_...           # secret key (server only — never exposed)
DIMEPAY_ENV=sandbox                 # sandbox | production
DIMEPAY_WEBHOOK_SECRET=             # reserved for HMAC verification when documented

# Admin auth (single admin from env).
ADMIN_EMAIL=owner@sooncomevilla.com
# ADMIN_PASSWORD_HASH accepts a bcrypt hash, but bcrypt hashes contain `$` which
# env systems mangle (dotenv-expand locally, host injectors). To be `$`-proof,
# provide the hash BASE64-ENCODED — auth.js decodes it automatically.
# Generate:
#   node -e "console.log(Buffer.from(require('bcryptjs').hashSync('your-password',12)).toString('base64'))"
ADMIN_PASSWORD_HASH=base64_of_your_bcrypt_hash
SESSION_SECRET=long-random-string-for-signing-session-jwts

# Cron + absolute base URL (used to build the DimePay webhookUrl).
CRON_SECRET=another-long-random-string
PUBLIC_BASE_URL=https://www.sooncomevilla.com
